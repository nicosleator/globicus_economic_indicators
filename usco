#download libraries
library(tidyverse)
library(readr)
library(dplyr)
library(readxl)
library(purrr)
library(DBI)
library(RMariaDB)
library(fredr)
source("econ_data_functions.R")

fredr_set_key("your_fred_api_key")

#connect to MariaDB
con <- dbConnect(MariaDB(),
                 user = 'your_username',
                 password = 'your_password',
                 dbname = 'fred',
                 host = '127.0.0.1')

#read and format files from fred
GDPC1 <- read_fred_from_maria(series_id = "GDPC1", value_name = "GDPC1") #same as excel
W875RX1 <- read_fred_from_maria(series_id = "W875RX1", value_name = "W875RX1") #similar to excel
CMRMTSPL <- pad_fred(read_fred_from_maria(series_id = "CMRMTSPL"), dbReadTable(con, "MTS")) %>% rename(CMRMTSPL = value)
INDPRO <- read_fred_from_maria(series_id = "INDPRO", value_name = "INDPRO") #similar to excel
PAYEMS <- read_fred_from_maria(series_id = "PAYEMS", value_name = "PAYEMS") #similar to excel
UNRATE <- read_fred_from_maria(series_id = "UNRATE", value_name = "UNRATE") #same as excel

write.csv(PAYEMS, "PAYEMS_260208.csv", row.names = FALSE)
write.csv(UNRATE, "UNRATE_260208.csv", row.names = FALSE)

#calculate change, absolute change, standard change and smoothed growth rate for all data
GDPC1 <- chg(GDPC1, "GDPC1", 157:nrow(GDPC1) , q = TRUE, smgr = FALSE, abs = TRUE, ave_dev = FALSE)
W875RX1 <- chg(W875RX1, "W875RX1", 26:nrow(W875RX1), smgr = TRUE, abs = TRUE, ave_dev = FALSE)
CMRMTSPL <- chg(CMRMTSPL, "CMRMTSPL", smgr = TRUE, abs = TRUE, ave_dev = FALSE)
INDPRO <- chg(INDPRO, "INDPRO", 157:660, smgr = TRUE, abs = TRUE, ave_dev = FALSE)
PAYEMS <- chg(PAYEMS, "PAYEMS",157:nrow(PAYEMS), smgr = TRUE, abs = TRUE, ave_dev = FALSE)
UNRATE <- chg(UNRATE, "UNRATE",157:nrow(UNRATE), subtract = TRUE, smgr_ave = TRUE, smgr = TRUE, abs = TRUE, ave_dev = FALSE)

#create a variable for average symmetric percent change in GDPC1, we will use this in the calculations later
GDPC1_ave_sym_pct_chg =  mean(GDPC1$chg[157:nrow(GDPC1)], na.rm = TRUE) * 4

#create a variable of dates by month
monthly_dates <- monthly_from_quartely_dates(PAYEMS)

view(GDPC1)
#create a monthly version of GDPC1
gdp <- q_to_m(monthly_dates, GDPC1, df_variable = st_chg, new_df_variable = gdp_chg)

#adds values from all of the data frames into a new data frame
usco_calc <- data.frame(date = monthly_dates)  # this should be a dataframe with a 'date' column

# Join each series by date
usco_calc <- usco_calc %>%
  left_join(gdp %>% select(date, gdp_chg), by = "date") %>%
  left_join(W875RX1 %>% select(date, st_chg) %>% rename(W875RX1_chg = st_chg), by = "date") %>%
  left_join(CMRMTSPL %>% select(date, st_chg) %>% rename(CMRMTSPL_chg = st_chg), by = "date") %>%
  left_join(INDPRO %>% select(date, st_chg) %>% rename(INDPRO_chg = st_chg), by = "date") %>%
  left_join(PAYEMS %>% select(date, st_chg) %>% rename(PAYEMS_chg = st_chg), by = "date") %>%
  left_join(UNRATE %>% select(date, st_chg) %>% mutate(UNRATE_chg = st_chg * -1) %>% select(date, UNRATE_chg), by = "date")


names(usco_calc) <- c("date", "gdp_chg", "W875RX1_chg", "CMRMTSPL_chg", "INDPRO_chg", "emp_chg", "UNRATE_chg") #names all of the columns in the usco calc data frame

usco_calc <- ave_rows(usco_calc, 2:7, 2, "ave_chg") #create a new column containing the averages of all values if there are at least three values in the row

ave_ave_chg = mean(usco_calc$ave_chg[157:528], na.rm = TRUE) * 12 #calculate the average of the average change x 12
ave_dev_chg = ave_dev(usco_calc$ave_chg[157:528]) #calculate the average deviation of the average change
usco_calc <- calc_custom_index(usco_calc, "ave_chg", "un_adj_index", 1) #create index based on average change

ave_un_adj_index = mean(usco_calc$un_adj_index[505:516], na.rm = TRUE) #calculate the average of the un-adjusted index
usco_calc <- usco_calc %>% mutate(rebased_ui = 100 * usco_calc$un_adj_index/ave_un_adj_index) #calculate the re-based ui

ave_chg_over_GDPC1 = ave_ave_chg/GDPC1_ave_sym_pct_chg #average of average change over GDPC1 symmetric percent change
usco_calc <- usco_calc %>% mutate(adj_chg = ave_chg/ave_chg_over_GDPC1) #calculate adjusted change

ave_adj_chg = mean(usco_calc$adj_chg[157:528], na.rm = TRUE) * 12 #calculate average adjusted change x 12
usco_calc <- calc_custom_index(usco_calc, "adj_chg", "initial_index", 1) #create index based on adjusted change

ave_initial_index = mean(usco_calc$initial_index[625:636], na.rm = TRUE) #calculate the average initial index
usco_calc <- usco_calc %>% mutate(final_index = 100 * usco_calc$initial_index/ave_initial_index) #calculate adjusted change
usco_calc <- ann_ave(usco_calc, "final_index", "smgr") #calculates the smoothed growth rate of the output index by finding the average of the previous 12 values and raising it by 12/6.5, then subtracting 1
usco_calc <- ave_rows(usco_calc, 2:5, 1, "output") #create a new column output containing the averages of first four variables if there are at least two values in the row

ave_output = mean(usco_calc$output[157:528], na.rm = TRUE) * 12 #calculate the average output x 12
ave_output_over_GDPC1 = ave_output/GDPC1_ave_sym_pct_chg #average output over GDPC1 average symmetric percent change
usco_calc <- usco_calc %>% mutate(adj_chg_2 = output/ave_output_over_GDPC1) #calculated output adjusted change

ave_adj_chg_2 = mean(usco_calc$adj_chg_2[157:528], na.rm = TRUE) * 12 #average output adjusted change
usco_calc <- calc_custom_index(usco_calc, "adj_chg_2", "initial_index_2", 3) #calculate index based off of adjusted changed 2

ave_initial_index_2 = mean(usco_calc$initial_index_2[625:636], na.rm = TRUE) #calculated initial index 2 average
usco_calc <- usco_calc %>% mutate(output_index = 100 * initial_index_2/ave_initial_index_2) #output index 2. year 2000 is index 100
usco_calc <- ann_ave(usco_calc, "output_index", "smgr_output_index") #calculates the smoothed growth rate of the output index by finding the average of the previous 12 values and raising it by 12/6.5, then subtracting 1
usco_calc <- smgr_div(usco_calc, "final_index", "smgr_final_index") #calculates the smoothed growth rate of the output index

view(usco_calc)
write.csv(usco_calc, "usco_calc_R_250910.csv", row.names = FALSE)
